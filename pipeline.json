pipeline {
    agent any
    
    parameters{
        string(name: 'DOCKER_TAG', defaultValue:'latest', description:'Docker tag')
    }
    tools{
        maven 'maven3'
    }
    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }
    
    stages {
        
        stage('Clean Worksapce') {
            steps {
                cleanWs()
            }
        }
      
        stage('Git Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/vipulkarke12/Multi-Tier-BankApp-CI.git'
            }
        }
        
        stage('Compile') {
            steps {
                sh "mvn compile"
            }
        }
        
        stage('Test') {
            steps {
                sh "mvn test -DskipTests=true"
            }
        }
        
        stage('File System Scan') {
            steps {
                sh "trivy fs --format table -o fs.html ."
            }
        }
        
        stage('Sonar Analysis') {
            steps {
                withSonarQubeEnv('sonar') {
                sh ''' $SCANNER_HOME/bin/sonar-scanner -Dsonar.projectKey=bankapp -Dsonar.projectName=bankapp -Dsonar.java.binaries=target '''
                }
            }
        }
        
        stage('Building & publish Nexus') {
         steps {
                    withMaven(globalMavenSettingsConfig: 'maven-settings-vipul', maven: 'maven3', traceability: true) {
                        sh "mvn deploy -DskipTests=true"
                    }
                }
            }
        
         stage('Docker Build and Tag') {
            steps {
                script{
                        withDockerRegistry(credentialsId: 'docker-cred') {
                            sh "docker build -t vipulkarke/bankapp:${params.DOCKER_TAG} ."
                        }
                }
            }
        }
        
         stage('Docker Image Scan ') {
            steps {
                script{
                        withDockerRegistry(credentialsId: 'docker-cred') {
                             sh "trivy image --format table -o dimage.html vipulkarke/bankapp:${params.DOCKER_TAG}"
                        }
                }
            }
        }
        
        stage('Docker Push') {
            steps {
                script{
                        withDockerRegistry(credentialsId: 'docker-cred') {
                             sh "docker push vipulkarke/bankapp:${params.DOCKER_TAG}"
                        }
                }
            }
        } 
        
                 stage('Update YAML Manifest in Other Repo') {
            steps {
                script {
                    withCredentials([gitUsernamePassword(credentialsId: 'git-cred', gitToolName: 'Default')]) {
                        sh '''
                            # Clean up existing directory from previous builds
                            rm -rf Multi-Tier-BankApp-CD
                            
                            # Clone your CD repository (removed www.)
                            git clone https://github.com/vipulkarke12/Multi-Tier-BankApp-CD.git
                            cd Multi-Tier-BankApp-CD
                            
                            # Verify directory structure
                            ls -l bankapp
                            
                            # Update the image tag in the deployment file
                            sed -i "s|image: vipulkarke/bankapp:.*|image: vipulkarke/bankapp:${DOCKER_TAG}|" bankapp/bankapp-ds.yml
                            
                            # Show the updated file
                            echo "Updated YAML file contents:"
                            cat bankapp/bankapp-ds.yml
                            
                            # Configure git
                            git config user.email "jenkins@ci.com"
                            git config user.name "Jenkins CI"
                            
                            # Commit and push
                            git add bankapp/bankapp-ds.yml
                            git commit -m "Update image tag to v${DOCKER_TAG}"
                            git push origin main
                        '''
                    }
                }
            }
        }
       
        
    
    }
}
